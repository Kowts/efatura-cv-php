{
    "name": "kowts/efatura-cv",
    "description": "Biblioteca PHP para validação e emissão de documentos fiscais electrónicos e-Fatura de Cabo Verde.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cabo-verde",
        "efatura",
        "faturacao",
        "fatura-eletronica",
        "dnre",
        "xades"
    ],
    "authors": [
        {
            "name": "Kowts",
            "homepage": "https://github.com/Kowts"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "nyholm/psr7": "^1.8",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "dompdf/dompdf": "^2.0 || ^3.0",
        "endroid/qr-code": "^5.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "suggest": {
        "dompdf/dompdf": "Necessário para gerar o DFA em PDF.",
        "endroid/qr-code": "Necessário para incorporar o QR Code no DFA."
    },
    "autoload": {
        "psr-4": {
            "Kowts\\Efatura\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kowts\\Efatura\\Tests\\": "tests/"
        },
        "files": [
            "tests/Fixtures.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs": "phpcs",
        "check": [
            "@cs",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
