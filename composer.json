{
    "name": "kowts/efatura-cv",
    "description": "Biblioteca PHP para validação e emissão de documentos fiscais electrónicos e-Fatura de Cabo Verde.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Kowts/efatura-cv-php",
    "keywords": [
        "cabo-verde",
        "efatura",
        "efatura-cv",
        "faturacao",
        "fatura-eletronica",
        "documentos-fiscais",
        "dnre",
        "xades",
        "xades-bes",
        "xml-signature",
        "laravel",
        "symfony",
        "yii2"
    ],
    "authors": [
        {
            "name": "Kowts",
            "homepage": "https://github.com/Kowts"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "nyholm/psr7": "^1.8",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "dompdf/dompdf": "^2.0 || ^3.0",
        "endroid/qr-code": "^5.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0"
    },
    "suggest": {
        "dompdf/dompdf": "Necessário para gerar o DFA em PDF.",
        "endroid/qr-code": "Necessário para incorporar o QR Code no DFA.",
        "ext-gd": "Necessário para renderizar o QR Code PNG do DFA.",
        "illuminate/support": "Necessário para usar o Service Provider Laravel.",
        "symfony/dependency-injection": "Necessário para usar o bundle Symfony.",
        "yiisoft/yii2": "Necessário para usar o componente Yii2."
    },
    "bin": [
        "bin/efatura"
    ],
    "autoload": {
        "psr-4": {
            "Kowts\\Efatura\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kowts\\Efatura\\Tests\\": "tests/"
        },
        "files": [
            "tests/Fixtures.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs": "phpcs",
        "docs:api": "@php tools/generate-api-docs.php",
        "docs:api:check": [
            "@docs:api",
            "git diff --exit-code docs/api-reference.md"
        ],
        "check": [
            "@cs",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kowts\\Efatura\\Bridge\\Laravel\\EfaturaServiceProvider"
            ]
        }
    },
    "support": {
        "issues": "https://github.com/Kowts/efatura-cv-php/issues",
        "source": "https://github.com/Kowts/efatura-cv-php"
    },
    "archive": {
        "name": "efatura-cv",
        "exclude": [
            "/.github",
            "/.phpunit.cache",
            "/build",
            "/dist*",
            "/tests",
            "/tools",
            "/vendor",
            "/.gitattributes",
            "/.gitignore",
            "/composer.lock",
            "/phpcs.xml.dist",
            "/phpstan.neon.dist",
            "/phpunit.xml.dist"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
