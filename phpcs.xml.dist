<?xml version="1.0"?>
<ruleset name="e-Fatura CV">
    <description>Regras de estilo PSR-12.</description>
    <file>src</file>
    <file>tests</file>
    <arg name="colors"/>
    <arg value="p"/>
    <rule ref="PSR12"/>
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="140"/>
            <property name="absoluteLineLimit" value="160"/>
        </properties>
    </rule>
</ruleset>
